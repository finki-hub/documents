# Environment
.env

# Original source files live in raw/ and ARE tracked (git is the source of truth,
# R2 is just a downstream mirror). Exception: the excluded originals must never be
# committed — salary tables, job systematization, internal reports, and personal data.
/raw/*odluka_za_plati*
/raw/*sistematizacija*
/raw/*finalen_izveshtaj*
/raw/*posrednici*
/raw/*odatoci_od_javen*
# Scratch dumps (e.g. raw text extractions) are not originals.
/raw/_*

# Python
__pycache__/
*.py[cod]

# Tooling caches
.mypy_cache/
.ruff_cache/
.venv/
